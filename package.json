{
  "name": "@philiprehberger/cuid-ts",
  "version": "0.2.0",
  "description": "Collision-resistant sortable unique IDs",
  "keywords": [
    "cuid",
    "id",
    "unique",
    "sortable",
    "collision-resistant",
    "uuid-alternative",
    "short-id",
    "timestamp"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-cuid.git"
  },
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-cuid/issues"
  },
  "homepage": "https://github.com/philiprehberger/ts-cuid#readme",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  }
}
